<Window x:Class="MagicSearch.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MagicSearch Settings"
        Width="560"
        Height="500"
        WindowStartupLocation="CenterOwner"
        Foreground="{StaticResource PrimaryTextBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#17191F"
        BorderBrush="#33FFFFFF"
        BorderThickness="1"
        CornerRadius="18"
        Padding="18">

        <Grid Margin="0,0,0,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Settings"
                       FontSize="20"
                       FontWeight="SemiBold" />
                <TextBlock Text="Choose indexed folders and change the global search hotkey."
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Margin="0,4,0,14" />
            </StackPanel>

            <Border Grid.Row="1"
                Background="#101217"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Global hotkey"
                               FontWeight="SemiBold" />
                        <TextBlock Text="This opens the MagicSearch overlay."
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="12"
                               Margin="0,3,0,0" />
                    </StackPanel>

                    <TextBox x:Name="HotkeyBox"
                         Grid.Column="1"
                         Height="34"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         TextAlignment="Center"
                         PreviewKeyDown="HotkeyBox_PreviewKeyDown" />

                    <Button Grid.Column="2"
                        Content="Reset"
                        Width="70"
                        Height="34"
                        Margin="8,0,0,0"
                        Click="ResetHotkey_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,43,0,69" Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Indexed folders"
                           FontSize="16"
                           FontWeight="SemiBold" />
                    <TextBlock Text="Folders added here are searched alongside Start Menu apps."
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,4,0,10" />
                </StackPanel>

                <ListBox x:Name="FoldersList"
                     Grid.Row="1"
                     Background="#101217"
                     BorderBrush="#33FFFFFF"
                     Foreground="{StaticResource PrimaryTextBrush}" Height="159" VerticalAlignment="Top" Margin="0,10,0,0" />
            </Grid>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Content="Add folder"
                    Width="104"
                    Height="34"
                    Click="AddFolder_Click" />
                <Button Grid.Column="1"
                    Content="Remove"
                    Width="86"
                    Height="34"
                    Margin="8,0,0,0"
                    Click="RemoveFolder_Click" />
                <Button Grid.Column="3"
                    Content="Cancel"
                    Width="86"
                    Height="34"
                    IsCancel="True" />
                <Button Grid.Column="4"
                    Content="Save &amp; Restart"
                    Width="86"
                    Height="34"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Click="Save_Click" />
                <Border
                    Margin="0,-276,0,289"
                    Padding="16,12"
                    Background="#101217"
                    BorderBrush="#2A3445"
                    BorderThickness="1"
                    CornerRadius="10" Grid.ColumnSpan="5">

                    <CheckBox
                    x:Name="StartWithWindowsCheckBox"
                    VerticalAlignment="Center"
                    Foreground="#DDE7F3"
                    FontSize="13"
                    Content="Start MagicSearch with Windows (Recommended)"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>