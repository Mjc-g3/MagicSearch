<Application x:Class="MagicSearch.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#EE17191F" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#3AFFFFFF" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9EA7B3" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4DA3FF" />
    </Application.Resources>
</Application>
