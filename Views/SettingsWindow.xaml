<Window x:Class="MagicSearch.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MagicSearch Settings"
        Width="560"
        Height="420"
        WindowStartupLocation="CenterOwner"
        Background="#17191F"
        Foreground="{StaticResource PrimaryTextBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Indexed folders"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="Folders added here are searched alongside Start Menu apps."
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Margin="0,4,0,14" />
        </StackPanel>

        <ListBox x:Name="FoldersList"
                 Grid.Row="1"
                 Background="#101217"
                 BorderBrush="#33FFFFFF"
                 Foreground="{StaticResource PrimaryTextBrush}" />

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Content="Add folder"
                    Width="104"
                    Height="34"
                    Click="AddFolder_Click" />
            <Button Grid.Column="1"
                    Content="Remove"
                    Width="86"
                    Height="34"
                    Margin="8,0,0,0"
                    Click="RemoveFolder_Click" />
            <Button Grid.Column="3"
                    Content="Cancel"
                    Width="86"
                    Height="34"
                    IsCancel="True" />
            <Button Grid.Column="4"
                    Content="Save"
                    Width="86"
                    Height="34"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Click="Save_Click" />
        </Grid>
    </Grid>
</Window>
